# Variabili d'ambiente di DietAI.
# In locale: copia in backend/.env. In produzione: mettile nelle Environment
# Variables di Coolify (il file .env non viene committato).

# --- Database (PostgreSQL) ---
# In locale con docker-compose.dev.yml: dietai / dietai / localhost / 5432 / dietai
# In produzione: DB_HOST è il nome interno della risorsa Postgres sulla rete Docker.
DB_USER=dietai
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dietai

# --- Auth ---
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=90
# false SOLO in locale (http). In produzione deve restare true.
COOKIE_SECURE=true

# --- Cifratura della API key di Claude ---
# Genera con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Cambiandola, la API key salvata non è più decifrabile e va reinserita.
ENCRYPTION_KEY=

# --- Utente unico dell'app (creato da `python -m app.seed`) ---
SEED_USER_EMAIL=tu@dietai.local
SEED_USER_PASSWORD=

# --- Modelli Claude (facoltativi) ---
# AI_MODEL_PLANNING=claude-opus-4-8
# AI_MODEL_CHAT=claude-opus-4-8
# AI_MAX_RETRIES=3

# NOTA: la API key di Anthropic NON va qui. La inserisce l'utente dalla UI e viene
# salvata cifrata nel database.
